@{
    ViewData["Title"] = "Inicio de Votación";
}

@if (ViewBag.Mensaje != null)
{
    <div class="alert alert-danger">
        @ViewBag.Mensaje
    </div>
}
else
{
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="card shadow-lg p-5 text-center" style="max-width: 400px; width: 100%; border-radius: 15px;">

            <h2 class="mb-4">🗳️ Votaciones</h2>

            <p class="mb-4 text-muted">
                Presione el botón para iniciar el proceso de votación
            </p>

            <form asp-action="Votation" method="get">
                <input type="hidden" name="idSede" value="@ViewBag.IdSede" />

                <button type="submit" class="btn btn-success btn-lg w-100">
                    Iniciar Votación
                </button>
            </form>

        </div>
    </div>
}
